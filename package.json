{
  "name": "logilog",
  "version": "0.0.1",
  "type": "module",
  "description": "Semantic log forensics: detect anomalies, cluster events, and generate AI-powered narratives from any log file.",
  "keywords": [
    "log-analysis",
    "anomaly-detection",
    "ml",
    "webgpu",
    "transformers",
    "embeddings",
    "forensics",
    "observability",
    "clustering",
    "vitest-reporter",
    "jest-reporter",
    "cli",
    "browser"
  ],
  "homepage": "https://tamirtapiro.github.io/Logilog/",
  "repository": {
    "type": "git",
    "url": "https://github.com/TamirTapiro/Logilog.git"
  },
  "bugs": {
    "url": "https://github.com/TamirTapiro/Logilog/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "logilog": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vitest": {
      "types": "./dist/reporters/vitest.d.ts",
      "import": "./dist/reporters/vitest.js",
      "require": "./dist/reporters/vitest.cjs"
    },
    "./jest": {
      "types": "./dist/reporters/jest.d.ts",
      "import": "./dist/reporters/jest.js",
      "require": "./dist/reporters/jest.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "peerDependencies": {
    "jest": ">=29.0.0",
    "onnxruntime-node": ">=1.14.0",
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    },
    "jest": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pkg": "tsup",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --config vitest.node.config.ts --reporter=verbose test/node-pipeline.test.ts",
    "test:cli": "vitest run --config vitest.node.config.ts --reporter=verbose test/cli.e2e.test.ts",
    "test:e2e": "playwright test",
    "lighthouse": "lhci autorun",
    "build:analyze": "ANALYZE=true vite build",
    "check-bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@huggingface/transformers": "^4.2.0",
    "browser-fs-access": "^0.38.0",
    "chalk": "^5.6.2",
    "comlink": "^4.4.2",
    "commander": "^14.0.3",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "onnxruntime-web": "^1.24.3",
    "ora": "^9.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "2.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/web-worker": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.2.4"
  }
}
